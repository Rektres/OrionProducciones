# Connection string Postgres de Supabase (Settings -> Database -> Connection string -> URI)
# Incluye password. Usar pooler (puerto 6543) y sslmode=require.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-xx.pooler.supabase.com:6543/postgres?sslmode=require

DJANGO_SECRET_KEY=cambia-esto-por-uno-largo-y-aleatorio
DEBUG=True

# Origenes permitidos (BFF local y prod). Separados por coma.
CORS_ALLOWED_ORIGINS=http://localhost:3001
ALLOWED_HOSTS=localhost,127.0.0.1
